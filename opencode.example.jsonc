{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "oracle-db": {
      "type": "local",
      "command": [
        "C:\\path\\to\\oracle-mcp\\.venv\\Scripts\\python.exe",
        "-m",
        "oracle_mcp",
        "--config",
        "C:\\path\\to\\oracle-mcp\\profiles.yaml"
      ],
      "cwd": "C:\\path\\to\\oracle-mcp",
      "enabled": true,
      "timeout": 30000
    }
  },
  "permission": {
    "*": "ask",
    "oracle-db_*": "allow"
  }
}
